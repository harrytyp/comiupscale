+void ScummEngine::renderHDComposite() {
+	if (!_hdBackgroundSurface.getPixels())
+		return;
+
+	VirtScreen *vs = &_virtscr[kMainVirtScreen];
+	int hdW = _hdBackgroundSurface.w;
+	int hdH = _hdBackgroundSurface.h;
+	int visW = MIN<int>(_screenWidth, vs->w - vs->xstart);
+	int visH = MIN<int>(_screenHeight, vs->h);
+
+	if (visW <= 0 || visH <= 0)
+		return;
+
+	Graphics::PixelFormat rgbaFmt(4, 8, 8, 8, 8, 0, 8, 16, 24);
+
+	// Allocate HD composite surface once
+	if (!_hdComposite.getPixels() ||
+		_hdComposite.w != hdW ||
+		_hdComposite.h != hdH) {
+		_hdComposite.free();
+		_hdComposite.create(hdW, hdH, rgbaFmt);
+	}
+
+	// Step 1: Copy HD background to composite surface, with camera offset
+	// For V7+, vs->xstart = camera._cur.x - _screenWidth/2
+	// Map this room pixel offset to HD coordinates
+	int64 camOffX = (int64)vs->xstart * hdW / MAX(1, _roomWidth);
+	camOffX = CLIP<int64>(camOffX, 0, hdW - 1);
+
+	// Copy HD background row by row (much faster than pixel-by-pixel)
+	for (int y = 0; y < hdH; y++) {
+		int64 hdSrcY = (int64)y * _hdBackgroundSurface.h / hdH;
+		hdSrcY = CLIP<int64>(hdSrcY, 0, _hdBackgroundSurface.h - 1);
+		int copyW = MIN(hdW, _hdBackgroundSurface.w - (int)camOffX);
+		if (copyW > 0) {
+			memcpy(_hdComposite.getBasePtr(0, y),
+			       _hdBackgroundSurface.getBasePtr((int)camOffX, (int)hdSrcY),
+			       copyW * 4);
+			// If camOffX caused us to run out of source pixels, fill remainder with black
+			if (copyW < hdW) {
+				memset(_hdComposite.getBasePtr(copyW, y), 0, (hdW - copyW) * 4);
+			}
+		} else {
+			memset(_hdComposite.getBasePtr(0, y), 0, hdW * 4);
+		}
+	}
+
+	// Step 2: Composite game content (8-bit → 32-bit via palette) over HD background
+	// Diff against clean background to only overlay foreground pixels.
+	// Clean background is populated per-strip in redrawBGStrip (room image only).
+	// Pixels that haven't been covered by a strip yet are treated as foreground.
+	for (int dy = 0; dy < hdH; dy++) {
+		int sy = dy * visH / hdH;
+		sy = CLIP(sy, 0, visH - 1);
+
+		for (int dx = 0; dx < hdW; dx++) {
+			int sx = dx * visW / hdW;
+			sx = CLIP(sx, 0, visW - 1);
+
+			// Read current game pixel (8-bit palette index) at visible screen position
+			uint8 curPix = *(const uint8 *)vs->getBasePtr(vs->xstart + sx, sy);
+
+			// Foreground if clean pixel not yet available, or differs from current
+			bool isForeground = true;
+			if (_hdCleanValid && sy < _hdCleanValidSize / visW) {
+				int pos = sy * visW + sx;
+				if (_hdCleanValid[pos]) {
+					uint8 cleanPix = *(const uint8 *)_hdCleanBackground.getBasePtr(sx, sy);
+					isForeground = (curPix != cleanPix);
+				}
+			}
+
+			if (isForeground) {
+				// Convert 8-bit palette index to 32-bit RGBA
+				uint8 r = _currentPalette[curPix * 3 + 0];
+				uint8 g = _currentPalette[curPix * 3 + 1];
+				uint8 b = _currentPalette[curPix * 3 + 2];
+				*((uint32 *)_hdComposite.getBasePtr(dx, dy)) =
+					r | (g << 8) | (b << 16) | (0xFF << 24);
+			}
+			// else: background pixel → HD background shows through (already in composit)
+		}
+	}
+
+	// Step 3: Copy the entire HD composite to the system buffer
+	_system->copyRectToScreen(_hdComposite.getPixels(), _hdComposite.pitch,
+	                          0, 0, hdW, hdH);
+
+	// HD debug dump — trigger on frame count OR room change
+	_hdFrameCount++;
+	if (_hdDebugDumpCount > 0) {
+		if (_hdFrameCount == _hdDebugDumpCount || 
+		    (_hdFrameCount > 10 && _currentRoom == _hdDebugDumpCount)) {
+			hdDebugDump();
+			_hdDebugDumpCount = 0; // one-shot
+		}
+	}
+}
+
+void ScummEngine::hdDebugDump() {
+	Common::DumpFile df;
+	char path[256];
+	
+	// 1. Dump HD composite surface (before cursor)
+	Graphics::Surface *screen = _system->lockScreen();
+	if (screen) {
+		snprintf(path, sizeof(path), "hd_dump_%d_composite.raw", _hdFrameCount);
+		df.open(Common::Path(path));
+		df.write(screen->getPixels(), screen->h * screen->pitch);
+		df.close();
+		_system->unlockScreen();
+		warning("HD DEBUG: composite saved to %s (%dx%d)", path, screen->w, screen->h);
+	}
+	
+	// 2. Dump HD composite surface (our internal 32-bit surface)
+	snprintf(path, sizeof(path), "hd_dump_%d_hdcomposite.raw", _hdFrameCount);
+	if (_hdComposite.getPixels()) {
+		df.open(Common::Path(path));
+		df.write(_hdComposite.getPixels(), _hdComposite.h * _hdComposite.pitch);
+		df.close();
+		warning("HD DEBUG: hdcomposite saved to %s (%dx%d)", path, _hdComposite.w, _hdComposite.h);
+	}
+	
+	// 3. Dump clean background + valid mask
+	VirtScreen *vs = &_virtscr[kMainVirtScreen];
+	snprintf(path, sizeof(path), "hd_dump_%d_clean.raw", _hdFrameCount);
+	if (_hdCleanBackground.getPixels()) {
+		df.open(Common::Path(path));
+		df.write(_hdCleanBackground.getPixels(), _hdCleanBackground.h * _hdCleanBackground.pitch);
+		df.close();
+		warning("HD DEBUG: clean saved to %s (%dx%d)", path, _hdCleanBackground.w, _hdCleanBackground.h);
+	}
+	
+	// 4. Dump cleanValid mask
+	snprintf(path, sizeof(path), "hd_dump_%d_valid.raw", _hdFrameCount);
+	if (_hdCleanValid && _hdCleanValidSize > 0) {
+		df.open(Common::Path(path));
+		df.write(_hdCleanValid, _hdCleanValidSize);
+		df.close();
+		warning("HD DEBUG: valid mask saved to %s (%d bytes)", path, _hdCleanValidSize);
+	}
+	
+	// 5. Dump game virtual screen (8-bit)
+	snprintf(path, sizeof(path), "hd_dump_%d_virtscr.raw", _hdFrameCount);
+	df.open(Common::Path(path));
+	for (int y = 0; y < vs->h; y++) {
+		df.write(vs->getBasePtr(vs->xstart, y), _screenWidth);
+	}
+	df.close();
+	warning("HD DEBUG: virtscr saved to %s", path);
+	
+	// 6. Dump palette
+	snprintf(path, sizeof(path), "hd_dump_%d_palette.txt", _hdFrameCount);
+	df.open(Common::Path(path));
+	char line[64];
+	for (int i = 0; i < 256; i++) {
+		snprintf(line, sizeof(line), "%3d %3d %3d %3d\n", i,
+			(int)_currentPalette[i*3], (int)_currentPalette[i*3+1], (int)_currentPalette[i*3+2]);
+		df.write(line, strlen(line));
+	}
+	df.close();
+	
+	// 7. Dump engine state
+	snprintf(path, sizeof(path), "hd_dump_%d_state.txt", _hdFrameCount);
+	df.open(Common::Path(path));
+	snprintf(line, sizeof(line), "frame=%d room=%d hdRoom=%d hdScale=%d\n",
+		_hdFrameCount, _currentRoom, _hdCurrentRoom, _hdScale);
+	df.write(line, strlen(line));
+	snprintf(line, sizeof(line), "screen=%dx%d roomW=%d roomH=%d\n",
+		_screenWidth, _screenHeight, _roomWidth, _roomHeight);
+	df.write(line, strlen(line));
+	snprintf(line, sizeof(line), "camera=(%d,%d) xstart=%d screenStartStrip=%d\n",
+		camera._cur.x, camera._cur.y, vs->xstart, _screenStartStrip);
+	df.write(line, strlen(line));
+	snprintf(line, sizeof(line), "mouse=(%d,%d) hdBg=(%dx%d) composite=(%dx%d)\n",
+		_mouse.x, _mouse.y,
+		_hdBackgroundSurface.w, _hdBackgroundSurface.h,
+		_hdComposite.w, _hdComposite.h);
+	df.write(line, strlen(line));
+	snprintf(line, sizeof(line), "hdBgPixels=%d cleanPixels=%d cleanValid=%d\n",
+		_hdBackgroundSurface.getPixels() ? 1 : 0,
+		_hdCleanBackground.getPixels() ? 1 : 0,
+		_hdCleanValid ? 1 : 0);
+	df.write(line, strlen(line));
+	snprintf(line, sizeof(line), "actorCount=%d fullRedraw=%d bgNeedsRedraw=%d\n",
+		_numActors, _fullRedraw ? 1 : 0, _bgNeedsRedraw ? 1 : 0);
+	df.write(line, strlen(line));
+	df.close();
+	
+	// Signal to OGL backend to capture framebuffer after next updateScreen()
+	
+	warning("HD DEBUG: state saved to %s", path);
 }
 
