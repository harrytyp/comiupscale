+	// HD background overlay: draw the high-res PNG over the screen
+	if (_hdCurrentRoom >= 0 && _hdBackgroundSurface.getPixels()) {
+		// The HD image is at 4x resolution. We downscale it to fit the screen.
+		Graphics::Surface *screen = _system->lockScreen();
+		if (screen) {
+			// Simple nearest-neighbor downscale from HD to screen size
+			uint32 hdW = _hdBackgroundSurface.w;
+			uint32 hdH = _hdBackgroundSurface.h;
+			float scaleX = (float)hdW / screen->w;
+			float scaleY = (float)hdH / screen->h;
+
+			for (int y = 0; y < screen->h && y < (int)hdH / scaleY; y++) {
+				for (int x = 0; x < screen->w && x < (int)hdW / scaleX; x++) {
+					uint32 hdX = (uint32)(x * scaleX);
+					uint32 hdY = (uint32)(y * scaleY);
+					uint32 pixel = *(const uint32 *)_hdBackgroundSurface.getBasePtr(hdX, hdY);
+					*(uint32 *)screen->getBasePtr(x, y) = pixel;
+				}
+			}
+			_system->unlockScreen();
+		}
+	}
 }
 
