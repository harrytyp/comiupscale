# COMI-HD Build Dependencies — Version Manifest
# All URLs are the canonical release sources.
# Used by build scripts to download/extract dependencies.

# ── LLVM MinGW (Windows cross-compiler) ────────────────
# Prebuilt toolchain for Linux → Windows cross-compilation
DEP_LLVM_MINGW_URL="https://github.com/mstorsjo/llvm-mingw/releases/download/20260616/llvm-mingw-20260616-ucrt-ubuntu-22.04-x86_64.tar.xz"
DEP_LLVM_MINGW_DIR="llvm-mingw-20260616-ucrt-ubuntu-22.04-x86_64"

# ── SDL2 (needed for both Linux AND Windows builds) ────
DEP_SDL2_VERSION="2.30.11"
DEP_SDL2_URL="https://github.com/libsdl-org/SDL/releases/download/release-2.30.11/SDL2-2.30.11.tar.gz"
DEP_SDL2_DIR="SDL2-2.30.11"

# ── zlib (needed for Windows cross-compile) ────────────
DEP_ZLIB_VERSION="1.3.1"
DEP_ZLIB_URL="https://zlib.net/fossils/zlib-1.3.1.tar.gz"
DEP_ZLIB_DIR="zlib-1.3.1"

# ── libpng (needed for Windows cross-compile) ──────────
DEP_LIBPNG_VERSION="1.6.44"
DEP_LIBPNG_URL="https://download.sourceforge.net/libpng/libpng-1.6.44.tar.gz"
DEP_LIBPNG_DIR="libpng-1.6.44"
